{
  "outputDirectory": "_site",
  "buildCommand": "bash ./scripts/vercel-build.sh",
  "devCommand": null,
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/content/index.html"
    },
    {
      "source": "/site-map.html",
      "destination": "/content/site-map.html"
    },
    {
      "source": "/project/:match*",
      "destination": "/content/project/:match*"
    },
    {
      "source": "/pipeline/:match*",
      "destination": "/content/pipeline/:match*"
    },
    {
      "source": "/data-primer/:match*",
      "destination": "/content/data-primer/:match*"
    },
    {
      "source": "/analysis/:match*",
      "destination": "/content/analysis/:match*"
    }
  ]
}
